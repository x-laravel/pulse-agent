# Laravel app key — her sunucu için aynı key kullanılmalı
# Üretmek için: php artisan key:generate --show
APP_KEY=base64:...

# Bu sunucunun Pulse dashboard'unda görünecek adı
PULSE_SERVER_NAME=my-server

# İzlenecek disk dizinleri (: ile ayır)
PULSE_SERVER_DIRECTORIES=/

# Ana Laravel uygulamasının MySQL bilgileri (pulse_* tablolarının olduğu DB)
DB_HOST=remote-mysql-host
DB_PORT=3306
DB_DATABASE=laravel_db
DB_USERNAME=
DB_PASSWORD=

{
    "name": "pulse/agent",
    "description": "Minimal Laravel Pulse server metrics agent",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0",
        "laravel/pulse": "^1.0",
        "x-laravel/pulse-oci-mysql": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
